<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}SnowTricks - Communauté Snowboard
			{% endblock %}
		</title>
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<link
		rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>🏂</text></svg>">

		{# Bootstrap 5 CSS #}
		<link
		href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
		{# Font Awesome (Icônes) #}
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
		{% block stylesheets %}<link rel="stylesheet" href="{{ asset('styles/app.css') }}">
		{% endblock %}
	</head>
	<body>
		{# La Navbar (on la détaillera plus tard) #}
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark d-none d-md-block">
			<div class="container">
				<a class="navbar-brand" href="{{ path('app_home') }}">SnowTricks</a>
			</div>
		</nav>

		{% block body %}{% endblock %}

		{# Bootstrap JS #}
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
		{% block javascripts %}{% endblock %}
		{# Footer #}
		<footer class="bg-dark text-white py-4 mt-5">
			<div class="container text-center">
				<p class="mb-0">&copy;
					{{ "now"|date("Y") }}
					SnowTricks - Communauté de passionnés</p>
				<small class="text-muted">Projet OpenClassrooms - Créé avec Symfony</small>
			</div>
		</footer>
		{# Tab Bar Mobile : Apparaît uniquement en dessous de 768px #}
		<div class="d-md-none bg-dark border-top position-fixed bottom-0 w-100" style="z-index: 1050; height: 60px;">
			<div
				class="d-flex justify-content-around align-items-center h-100">
				{# 1. Home #}
				<a href="{{ path('app_home') }}" class="text-white">
					<i class="fas fa-home fs-4"></i>
				</a>

				{# 2. Le Signet (Centre) - Correspond au visuel PDF #}
				<a href="#" class="text-white">
					<i class="fas fa-bookmark fs-4"></i>
				</a>

				{# 3. Login / Logout #}
				{% if app.user %}
					<a
						href="#" class="text-white">
						{# Remplacer # par path('app_logout') plus tard #}
						<i class="fas fa-sign-out-alt fs-4"></i>
					</a>
				{% else %}
					<a
						href="#" class="text-white">
						{# Remplacer # par path('app_login') plus tard #}
						<i class="fas fa-sign-in fs-4"></i>
					</a>
				{% endif %}
			</div>
		</div>

		<style>
			/* On ajoute un padding en bas du body sur mobile pour que le footer 
       ou le contenu ne soit pas caché par la barre fixe */
			@media(max-width: 767.98px) {
				body {
					padding-bottom: 60px;
				}
			}
		</style>


		{# Petit JS pour l'ancre #}
		<script>
			window.onscroll = function () {
let btn = document.getElementById("backToTop");
if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
btn.style.display = "flex";
} else {
btn.style.display = "none";
}
};
		</script>
	</body>
</html>
