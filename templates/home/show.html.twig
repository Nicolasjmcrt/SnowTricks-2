{% extends 'base.html.twig' %}

{% block title %}
	{{ trick.name }}
	- SnowTricks
{% endblock %}

{% block body %}
	{# 1. Hero Banner (Image à la une) #}
	{% set mainImage = trick.images|length > 0 ? trick.images[0].name : asset('images/default-trick.png') %}

	<section class="position-relative text-center text-white mb-5" style="height: 75vh; background: url('{{ mainImage }}') center/cover no-repeat;">
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-25"></div>

		<div class="position-absolute top-50 start-50 translate-middle w-100">
			<h1 class="display-1 fw-bold text-uppercase shadow-lg">{{ trick.name }}</h1>
		</div>

		{# Note 51 : Uniquement si connecté #}
		{% if app.user %}
			<div class="position-absolute top-0 end-0 m-3 p-2 bg-white rounded shadow-sm">
				<a href="#" class="text-primary me-2">
					<i class="fas fa-pencil-alt"></i>
				</a>
				<a href="#" class="text-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
					<i class="fas fa-trash-alt"></i>
				</a>
			</div>
		{% endif %}
	</section>

	<div
		class="container">
		{# 2. Médias (Toggle Mobile) #}
		<div class="text-center d-md-none mb-4">
			<button class="btn btn-primary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#mediaContainer">
				<i class="fas fa-images me-2"></i>Afficher les médias
			</button>
		</div>

		{# 3. Galerie des Médias #}
		<div class="collapse d-md-flex row row-cols-1 row-cols-sm-2 row-cols-md-4 row-cols-lg-5 g-3 mb-5 justify-content-center" id="mediaContainer">
			{% for image in trick.images|slice(1) %}
				<div class="col">
					<div class="card shadow-sm h-100">
						<img src="{{ image.name }}" class="img-fluid rounded card-img-top" alt="Illustration" style="height: 150px; object-fit: cover;">
					</div>
				</div>
			{% endfor %}

			{% for video in trick.videos %}
				<div class="col">
					<div class="ratio ratio-16x9 shadow-sm border rounded overflow-hidden h-100">
						<iframe src="{{ video.url }}" title="YouTube video player" allowfullscreen></iframe>
					</div>
				</div>
			{% endfor %}
		</div>

		{# 4. Description et Infos (Note 60) #}
		<article class="row justify-content-center">
			<div class="col-lg-10">
				<p class="fs-5 mb-5 text-start" style="white-space: pre-line;">{{ trick.description }}</p>

				{# Bloc Info conforme Note 60 #}
				<div class="d-flex justify-content-center flex-wrap gap-4 py-3 mb-5 border-top border-bottom bg-light">
					<span class="badge bg-dark p-2 px-3">Groupe :
						{{ trick.category.name }}</span>
					<span class="badge bg-secondary p-2 px-3">Créé le :
						{{ trick.createdAt|date('d/m/Y') }}</span>
					{% if trick.updatedAt %}
						<span class="badge bg-secondary p-2 px-3">Modifié le :
							{{ trick.updatedAt|date('d/m/Y') }}</span>
					{% endif %}
				</div>
			</div>
		</article>

		<hr
		class="w-75 mx-auto my-5">

		{# 5. Section Commentaires (Note 67 & 68) #}
		<section class="row justify-content-center my-5">
			<div
				class="col-lg-8">
				{# Formulaire de saisie (Simulé pour l'instant - Note Page 4) #}
				{% if app.user %}
					<div class="mb-5">
						<form class="p-4 border rounded shadow-sm bg-white">
							<div class="mb-3">
								<textarea class="form-control" placeholder="Laissez un commentaire..." rows="3"></textarea>
							</div>
							<div class="text-end">
								<button type="submit" class="btn btn-primary">Laisser un commentaire</button>
							</div>
						</form>
					</div>
				{% endif %}

				<h3 class="mb-4 text-center border-bottom pb-3">{{ trick.comments|length }}
					Commentaires</h3>

				{% for comment in trick.comments %}
					<div class="d-flex mb-4 p-3 border-bottom">
						<img src="https://i.pravatar.cc/150?u={{ comment.user.email }}" class="rounded-circle me-3 border shadow-sm" alt="Avatar" width="50" height="50">
						<div>
							<div class="fw-bold text-primary">{{ comment.user.username }}
								<small class="text-muted fw-normal ms-2">le
									{{ comment.createdAt|date('d/m/Y à H:i') }}</small>
							</div>
							<div class="mt-2 text-secondary">{{ comment.content }}</div>
						</div>
					</div>
				{% else %}
					<div class="alert alert-light text-center border">Aucun commentaire pour le moment.</div>
				{% endfor %}

				{# Bouton Load More Commentaires (Note 68) #}
				{% if trick.comments|length > 5 %}
					<div class="text-center mt-4">
						<button class="btn btn-outline-primary shadow-sm px-4">Charger plus de commentaires</button>
					</div>
				{% endif %}
			</div>
		</section>
	</div>

	{# MODALE DE SUPPRESSION (Note 26) #}
	<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header bg-danger text-white">
					<h5 class="modal-title" id="deleteModalLabel text-white">Confirmation de suppression</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body p-4 text-center">
					<i class="fas fa-exclamation-triangle text-warning display-4 mb-3"></i>
					<p class="fs-5">Êtes-vous sûr de vouloir supprimer la figure
						<strong>{{ trick.name }}</strong>
						?</p>
					<p class="text-muted small">Cette action est irréversible.</p>
				</div>
				<div class="modal-footer justify-content-center border-0 pb-4">
					<button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Annuler</button>
					<button type="button" class="btn btn-danger px-4">Supprimer définitivement</button>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
