{% extends 'base.html.twig' %}

{% block title %}
	{{ trick.name }}
	- SnowTricks
{% endblock %}

{% block body %}
	{# 1. Hero Banner #}
	<section class="position-relative text-center text-white mb-5" style="height: 70vh; background: url('{{ trick.images|length > 0 ? trick.images[0].name : 'https://picsum.photos/1200/600' }}') center/cover no-repeat;">
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-25"></div>
		<div class="position-absolute top-50 start-50 translate-middle w-100">
			<h1 class="display-1 fw-bold text-uppercase shadow-lg">{{ trick.name }}</h1>
		</div>

		{# Boutons d'action (visuels) #}
		<div class="position-absolute top-0 end-0 m-3 p-2 bg-white rounded shadow-sm">
			<a href="#" class="text-primary me-2">
				<i class="fas fa-pencil"></i>
			</a>
			<a href="#" class="text-danger">
				<i class="fas fa-trash"></i>
			</a>
		</div>
	</section>

	<div
		class="container">
		{# 2. Bouton Toggle Mobile (Visible uniquement sur mobile < 768px) #}
		<div class="text-center d-md-none mb-4">
			<button class="btn btn-primary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#mediaContainer" aria-expanded="false" aria-controls="mediaContainer">
				<i class="fas fa-images me-2"></i>Afficher les médias
			</button>
		</div>

		{# 3. Galerie des Médias (Masquée par défaut sur mobile, toujours visible sur Desktop) #}
		<div
			class="collapse d-md-flex row row-cols-1 row-cols-sm-2 row-cols-md-4 row-cols-lg-5 g-3 mb-5 justify-content-center" id="mediaContainer">

			{# Boucle Images (on saute la première qui est en Hero) #}
			{% for image in trick.images|slice(1) %}
				<div class="col">
					<div class="card shadow-sm h-100">
						<img src="{{ image.name }}" class="img-fluid rounded card-img-top" alt="Illustration" style="height: 150px; object-fit: cover;">
					</div>
				</div>
			{% endfor %}

			{# Boucle Vidéos #}
			{% for video in trick.videos %}
				<div class="col">
					<div class="ratio ratio-16x9 shadow-sm border rounded overflow-hidden h-100">
						<iframe src="{{ video.url }}" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				</div>
			{% endfor %}
		</div>

		{# 4. Description et Infos #}
		<article class="row justify-content-center">
			<div class="col-lg-10 text-center">
				<p class="fs-5 mb-5 text-start" style="white-space: pre-line;">{{ trick.description }}</p>

				<div class="d-flex flex-wrap justify-content-center gap-3 mb-5">
					<span class="badge bg-info text-dark p-2">
						<i class="fas fa-layer-group me-1"></i>
						{{ trick.category.name }}</span>
					<span class="badge bg-light text-dark border p-2">
						<i class="fas fa-calendar-plus me-1"></i>
						{{ trick.createdAt|date('d/m/Y') }}</span>
					{% if trick.updatedAt %}
						<span class="badge bg-light text-dark border p-2">
							<i class="fas fa-history me-1"></i>
							Modifié le
							{{ trick.updatedAt|date('d/m/Y') }}</span>
					{% endif %}
				</div>
				<hr class="w-75 mx-auto">
			</div>
		</article>

		{# 5. Section Commentaires #}
		<section class="row justify-content-center my-5">
			<div class="col-lg-8">
				<h3 class="mb-4 text-center">
					<i class="fas fa-comments me-2"></i>
					{{ trick.comments|length }}
					Commentaires</h3>

				{% for comment in trick.comments %}
					<div class="d-flex mb-4 p-3 border rounded shadow-sm bg-white">
						<img src="https://i.pravatar.cc/150?u={{ comment.user.email }}" class="rounded-circle me-3 shadow-sm" alt="Avatar" width="50" height="50">
						<div>
							<div class="fw-bold">{{ comment.user.username }}
								<small class="text-muted fw-normal ms-2">le
									{{ comment.createdAt|date('d/m/Y à H:i') }}</small>
							</div>
							<div class="mt-1">{{ comment.content }}</div>
						</div>
					</div>
				{% else %}
					<div class="alert alert-light text-center border">
						Aucun commentaire pour le moment. Soyez le premier à réagir !
					</div>
				{% endfor %}
			</div>
		</section>
	</div>
{% endblock %}
