{% extends 'base.html.twig' %}

{% block title %}Accueil - SnowTricks
{% endblock %}

{% block body %}
	{# Hero Header #}
	<section
		class="position-relative w-100 d-flex align-items-center justify-content-center text-white" style="height: calc(100vh - 56px); background: url('https://images.unsplash.com/photo-1550096141-7263640aa48c?q=80&w=2070') center/cover no-repeat;">

		{# Overlay pour lisibilité #}
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-25"></div>

		{# Titre / Phrase d'accroche au centre [cite: 2, 32] #}
		<div class="z-3 text-center">
			<h1 class="display-5 fw-bold text-uppercase">Ride the mountain</h1>
			<p class="fs-4">Partagez vos meilleures figures de snowboard avec la communauté.</p>
		</div>

		{# Le bouton/flèche pour descendre [cite: 25, 34, 35] #}
		<a href="#tricks-list" class="position-absolute bottom-0 end-0 m-4 text-white fs-1 animate-bounce">
			<i class="fas fa-arrow-down"></i>
		</a>
	</section>

	<div class="container my-5" id="tricks-list">
		<div class="row row-cols-1 row-cols-md-3 g-4">
			{% for trick in tricks %}
				<div class="col">
					<div
						class="card h-100 shadow-sm">
						{# On prend la première image du trick ou un placeholder #}
						<a href="{{ path('app_trick_show', {'slug': trick.slug}) }}">
							<img src="{{ trick.images|length > 0 ? trick.images[0].name : 'https://picsum.photos/400/300' }}" class="card-img-top" alt="{{ trick.name }}">
						</a>
						<div class="card-body d-flex justify-content-between align-items-center">
							<h5 class="card-title mb-0">
								<a href="{{ path('app_trick_show', {'slug': trick.slug}) }}" class="text-decoration-none text-dark text-capitalize fw-bold">
									{{ trick.name }}
								</a>
							</h5>

							<div
								class="d-flex align-items-center gap-2">


								{# Icônes d'édition (réservées au futur système d'auth) #}
								{% if app.user %}
									<a href="#" class="text-primary">
										<i class="fas fa-pencil"></i>
									</a>
									<a href="#" class="text-danger">
										<i class="fas fa-trash"></i>
									</a>
								{% endif %}
							</div>
						</div>
						<div class="card-footer bg-white border-top-0">
							<span class="badge bg-info text-dark">{{ trick.category.name }}</span>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
		{# --- LE BOUTON ICI --- #}
		<div class="text-center my-5" id="load-more-container">
			<button class="btn btn-primary btn-lg shadow-sm" id="loadMoreBtn">
				<i class="fas fa-plus-circle me-2"></i>Charger plus
			</button>
		</div>
	</div>
	
	{# Bouton de remontée : conditionné par le nombre de tricks (Note 28) #}
		{% if tricks|length > 15 %}
			<a href="#top" id="backToTop" class="btn btn-primary rounded-circle position-fixed shadow d-none" style="bottom: 20px; right: 20px; z-index: 1000; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;"> <i class="fas fa-arrow-up"></i>
		</a>
	{% endif %}
	<script>
		window.addEventListener('scroll', function () {
const backToTop = document.getElementById('backToTop');
const heroHeight = window.innerHeight - 56; // La hauteur de ta Hero Banner

if (backToTop) {
if (window.scrollY > heroHeight) {
backToTop.classList.remove('d-none');
backToTop.classList.add('d-flex'); // d-flex pour centrer l'icône
} else {
backToTop.classList.remove('d-flex');
backToTop.classList.add('d-none');
}
}
});
	</script>
{% endblock %}
