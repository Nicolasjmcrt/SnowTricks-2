{% extends 'base.html.twig' %}

{% block title %}Accueil - SnowTricks{% endblock %}

{% block body %}
    {# Hero Header #}
    <div class="p-5 mb-4 bg-light rounded-3 text-center shadow-sm" style="background: url('https://images.unsplash.com/photo-1550096141-7263640aa48c?q=80&w=2070') center/cover; min-height: 70vh; display: flex; align-items: center; justify-content: center;">
        <div class="container-fluid py-5 bg-dark bg-opacity-50 text-white rounded">
            <h1 class="display-5 fw-bold text-uppercase">Ride the mountain</h1>
            <p class="fs-4">Partagez vos meilleures figures de snowboard avec la communauté.</p>
        </div>
    </div>

    <div class="container my-5">
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for trick in tricks %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        {# On prend la première image du trick ou un placeholder #}
                        <img src="{{ trick.images|length > 0 ? trick.images[0].name : 'https://picsum.photos/400/300' }}" class="card-img-top" alt="{{ trick.name }}" style="height: 200px; object-fit: cover;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0 text-capitalize">{{ trick.name }}</h5>
                            <div class="actions">
                                <a href="#" class="text-primary me-2"><i class="fas fa-pencil"></i></a>
                                <a href="#" class="text-danger"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <span class="badge bg-info text-dark">{{ trick.category.name }}</span>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}